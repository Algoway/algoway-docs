        </script>

        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "What fields are required in AlgoWay JSON?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "The core AlgoWay JSON fields are platform_name, ticker, order_action and order_contracts for normal entry orders. For closeall, order_contracts is not required."
              }
            },
            {
              "@type": "Question",
              "name": "What values can order_action use?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Common order_action values are buy, sell, flat, closeall, modify and breakeven. AlgoWay can normalize long to buy, short to sell and close to flat."
              }
            },
            {
              "@type": "Question",
              "name": "How do I close all positions with AlgoWay JSON?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Use order_action with the value closeall and include platform_name and ticker. Do not include order_contracts. MetaTrader 5 users need AlgoWay EA version 2.10b or newer."
              }
            },
            {
              "@type": "Question",
              "name": "What is the difference between stop_loss and sl_price?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "stop_loss is a distance-style field, often interpreted as points or pips depending on the route. sl_price is an absolute Stop Loss price level."
              }
            },
            {
              "@type": "Question",
              "name": "Does trailing_pips work on every platform?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "No. trailing_pips is route-dependent. Some platforms process it directly, while others ignore it or require EA-side or platform-side trailing logic."
              }
            },
            {
              "@type": "Question",
              "name": "How do I send a limit or stop order with AlgoWay JSON?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Use order_type with value limit or stop and include price as the requested entry price. If order_type is missing, AlgoWay treats the order as market."
              }
            },
            {
              "@type": "Question",
              "name": "What does trade_type do in AlgoWay JSON?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "trade_type overrides the webhook Trade Type for one specific order. Supported values are hedge, netting, opposite and inverse. If trade_type is missing, AlgoWay uses the webhook settings."
              }
            },
            {
              "@type": "Question",
              "name": "What does close_side do?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "close_side is used with order_action flat in hedge mode to close only long or only short positions. If omitted, the handler may close all matching positions on the symbol."
              }
            }
          ]
        }
        </script>`;

