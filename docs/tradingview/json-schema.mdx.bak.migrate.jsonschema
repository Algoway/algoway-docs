                <li><a href="#closeall">closeall: close all positions</a></li>
                <li><a href="#order-type">order_type: market, limit and stop</a></li>
                <li><a href="#trade-type">trade_type override</a></li>
                <li><a href="#optional">Optional fields</a></li>
                <li><a href="#sltp">SL/TP fields</a></li>
                <li><a href="#trailing">trailing_pips support</a></li>
