                            }
                  },
                  "mainEntityOfPage": {
                            "@type": "WebPage",
                            "@id": "https://algoway.trade/blog/json-schema-guide.html"
                  },
                  "image": "https://algoway.trade/static/img/social.jpg",
                  "dateModified": "2026-05-15T00:00:00+00:00",
                  "articleSection": "Webhook JSON Schema",
